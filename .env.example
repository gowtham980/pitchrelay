# Optional: enable live LLM. Without keys, PitchRelay uses deterministic mock GenAI.
# LLM_PROVIDER=openai | gemini | mock
LLM_PROVIDER=mock

# OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=

# App
NEXT_PUBLIC_APP_NAME=PitchRelay

# Optional write protection for mutating APIs (incidents, decisions POST, scenarios, telemetry tick).
# Leave unset for open local demo. On public deploys, set a long random string.
# Browser same-origin UI requests still work; external callers need header: x-demo-key: <value>
# DEMO_WRITE_KEY=

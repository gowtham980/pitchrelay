# Optional: enable live LLM. Without keys, PitchRelay uses deterministic mock GenAI.
# LLM_PROVIDER=openai | gemini | mock
LLM_PROVIDER=mock

# OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=

# App
NEXT_PUBLIC_APP_NAME=PitchRelay
